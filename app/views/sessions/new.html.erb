<% content_for :title, "Login | Document Portal" %>

<section class="login-shell">
  <div class="brand-panel">
    <div class="brand-mark">DP</div>
    <p class="eyebrow">Secure document access</p>
    <h1>Admins upload documents. Users download after OTP approval.</h1>
    <p class="lead">Professional portal with approval-style OTP security, clean dashboards, and responsive screens.</p>
    <div class="feature-strip">
      <span>Role based login</span>
      <span>Admin OTP</span>
      <span>Secure downloads</span>
    </div>
  </div>

  <div class="auth-card">
    <h2>Login</h2>
    <p>Continue with your department account.</p>

    <%= form_with url: login_path, class: "form-stack" do |form| %>
      <label>
        Email
        <%= form.email_field :email, required: true, autofocus: true, placeholder: "admin@example.com" %>
      </label>
      <label>
        Password
        <%= form.password_field :password, required: true, placeholder: "password" %>
      </label>
      <%= form.submit "Login", class: "btn btn-primary" %>
    <% end %>
  </div>
</section>
