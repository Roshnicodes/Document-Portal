<% content_for :title, "#{@document.title} | Document Portal" %>

<section class="form-page">
  <div class="panel form-panel">
    <div class="panel-heading">
      <div>
        <p class="eyebrow">Document details</p>
        <h1><%= @document.title %></h1>
      </div>
      <%= link_to "Back", root_path, class: "btn btn-ghost" %>
    </div>

    <div class="detail-grid">
      <div>
        <span>Folder</span>
        <strong><%= @document.folder_label %></strong>
      </div>
      <div>
        <span>File name</span>
        <strong><%= @document.file_name %></strong>
      </div>
      <div>
        <span>Path</span>
        <strong><%= @document.display_path %></strong>
      </div>
      <div>
        <span>File size</span>
        <strong><%= @document.file_size %></strong>
      </div>
      <div>
        <span>Uploaded by</span>
        <strong><%= @document.uploaded_by.name %></strong>
      </div>
    </div>

    <p class="detail-copy"><%= @document.description.presence || "No description added." %></p>

    <% unless admin_user? %>
      <%= form_with url: request_otp_document_path(@document), method: :post, local: true, class: "otp-request-form document-otp-request" do |form| %>
        <div class="purpose-field">
          <div>
            <%= form.label :download_purpose, "Purpose of download" %>
            <span>Minimum <%= DownloadRequest::MIN_PURPOSE_WORDS %> words required</span>
          </div>
          <%= form.text_area :download_purpose, required: true, maxlength: 1000, rows: 6, placeholder: "Write the download purpose in at least 50 words" %>
        </div>
        <div class="purpose-actions">
          <span>OTP will be requested after purpose review.</span>
          <%= form.submit "Request OTP", class: "btn btn-primary" %>
        </div>
      <% end %>
    <% end %>
  </div>
</section>
