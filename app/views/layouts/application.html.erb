<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Document Portal" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Document Portal">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>

  <body class="<%= current_user ? "app-body" : "auth-body" %>">
    <div class="app-background"></div>
    <% if current_user %>
      <header class="topbar">
        <%= link_to root_path, class: "topbar-brand" do %>
          <span>DP</span>
          <strong>Document Portal</strong>
        <% end %>
        <nav>
          <span><%= current_user.name %> · <%= current_user.effective_role.titleize %></span>
          <%= link_to "Profile", edit_profile_path, class: "btn btn-ghost" %>
          <%= button_to "Logout", logout_path, method: :delete, class: "btn btn-ghost" %>
        </nav>
      </header>
    <% end %>

    <main class="app-container">
      <% flash.each do |type, message| %>
        <div class="flash <%= type == "alert" ? "flash-alert" : "flash-notice" %>"><%= message %></div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
